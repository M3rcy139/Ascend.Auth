{
  "Logging": {
    "ApplicationName": "Ascend.AuthService",
    "DefaultLogLevel": "Information",
    "AspNetCoreLogLevel": "Warning",
    "ConsoleLogLevel": "Information",
    "FileLogLevel": "Information",
    "ElasticSearchLogLevel": "Information",
    "FilePath": "logs/log-.json",
    "RetainedFileCountLimit": 7,
    "ElasticIndexFormat": "ascend-logs-",
    "ElasticSearchNumberOfShards": 2,
    "ElasticSearchNumberOfReplicas": 1
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AscendAuthDbContext": "Host=localhost;User ID=postgres;Password=1234;Port=5432;Database=Ascend.AuthService;"
  },
  "JwtOptions": {
    "SecretKey": "secretkeysecretkeysecretkeysecretkeysecretkey",
    "ExpiresHours": "12"
  },
  "RefreshTokenOptions": {
    "ExpiryDays": "7"
  },
  "ElasticConfiguration": {
    "Uri": "http://localhost:9200"
  },
  "GrpcServices": {
    "PersonService": "https://localhost:7011"
  }
}
